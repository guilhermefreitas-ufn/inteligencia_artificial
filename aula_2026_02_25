B) Problema das Jarras
Jarra1 suporta 4 litros
Jarra2 suporta 3 litros
Torneira que jorra água infinitamente

Objetivo: Deixar em uma das jarras 2 litros

r1 - encher J1 (j1 = 4)
r2 = encher J2 (j2 = 3)
r3 = esvaziar J1 (j1 = 0)
r4 = esvaziar J2 (j2 = 0)
r5 = despejarJ1J2
r6 = despejarJ2J3

class Estado
{
  int j1;
  int j2;

  public Estado(int j1, int j2)
  {
    this.j1 = j1;
    this.j2 = j2;
  }

  public boolean ehMeta()
  {
    return (this.j1 == 2 && this.j2 ==0) || (this.j2 == 2 && this.j1 == 0);
  }

  public void encherJ1()
  {
    this.j1 = 4;
  }

  public void encherJ2()
  {
    this.j2 = 3;
  }

  public void esvaziarJ1()
  {
    this.j1 = 0;
  }

  public void esvaziarJ2()
  {
    this.j2 = 0;
  }

  public void despejarJ1J2()
  {
    int jarra1 = this.j1;
    int jarra2 = this.j2;

    if(jarra1 > (3 - jarra2))
    {
      jarra1 = jarra1 - (3 - jarra2);
      jarra1 = 3;
    }
    else
    {
      jarra2 += jarra1;
      jarra1 = 0;
    }

    Estado novo = new Estado(jarra1, jarra2)
    
    if(!visitados.contains(novo))
    {
      visitados.add(novo);
    }
  }

  public void despejarJ2J1()
  {
    int jarra1 = this.j1;
    int jarra2 = this.j2;

    if(jarra2 > (4 - jarra1))
    {
      jarra2 = jarra2 - (4 - jarra1);
      jarra2 = 4;
    }
    else
    {
      jarra1 += jarra2;
      jarra2 = 0;
    }

    Estado novo = new Estado(jarra1, jarra2)
    
    if(!visitados.contains(novo))
    {
      visitados.add(novo);
    }
  }

}
