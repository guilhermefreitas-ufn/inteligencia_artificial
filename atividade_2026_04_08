%7. Empilhamento: Use fatos sobre(BlocoA, BlocoB) (A está em cima de B) e no_chao(BlocoB).
%Crie a regra abaixo(X,Y) e a regra bloco_livre(X) (se não há nada sobre ele)

sobre(azul, vermelho).
sobre(vermelho, amarelo).

no_chao(amarelo).

abaixo(X, Y) :-
    sobre(Y, X).

abaixo(X, Y) :-
    sobre(Intermediario, X),
    sobre(Y, Intermediario).

bloco_livre(X) :-
    not(abaixo(X,_)).

