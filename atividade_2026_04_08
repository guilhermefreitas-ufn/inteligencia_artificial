%1. Pré-requisitos: Crie fatos disciplina(Nome) e pre_requisito(Anterior, Posterior).
%Escreva uma regra pode_cursar(Aluno, Disciplina) que verifica se o aluno já completou os requisitos necessários.
%vai precisar criar JaCursou(Aluno,Disciplina)

disciplina(algoritmos).
disciplina(poo).
disciplina(motores).

pre_requisito(algoritmos, poo).
pre_requisito(poo, motores).

ja_cursou(guilherme, algoritmos).
ja_cursou(zamba, poo).

pode_cursar(Aluno, Disciplina) :-
    ja_cursou(Aluno, PreRequisito),
    pre_requisito(PreRequisito, Disciplina).

%2. Aprovação: Com fatos nota(Aluno, Disciplina, Valor), crie a regra aprovado(Aluno, Disciplina) (nota ≥ 7.0)
%e reprovado(Aluno, Disciplina) (nota < 7.0).

nota(guilherme, algoritmos, 10).
nota(guilherme, poo, 7).
nota(zamba, poo, 10).
nota(zamba, motores, 8).
nota(clarissa, algoritmos, 6).
nota(clarissa, motores, 3).

aprovado(Aluno, Disciplina) :-
    nota(Aluno, Disciplina, Nota),
    Nota >= 7.0.

reprovado(Aluno, Disciplina) :-
    nota(Aluno, Disciplina, Nota),
    Nota < 7.0.

