%repetição segue 3 fases clássicas/obrigatórias
%for (int i = 0; i < 4; i++)
%i. INICIALIZAÇÃO DA VARIÁVEL DE CONTROLE -> int i = 0
%ii. TESTE DE PARADA -> i < 4
%iii. TRANSFORMAÇÃO DA VARIÁVEL DE CONTROLE -> i++

%Exemplo:
%ii. TESTE DE PARADA
escreverDecresc(Numero) :-
  Numero == 0,
  !. %break

escreverDecresc(Numero) :-
  weiteln(Numero),
  Proximo is Numero - 1, %iii. TRANSFORMAÇÃO DA VARIÁVEL DE CONTROLE
  escreverDecresc(Proximo).

escreverCresc(Numero) :-
  Numero == 0,
  !. %break

escreverCresc(Numero) :-
  Proximo is Numero - 1,
  escrever(Proximo), %aqui, começa o empilhamento. Ocorre uma parada da execução atual para chamar novamente a função
  writeln(Numero).

%em prolog regras de recursão sempre são um par e a primeira é sempre a regra de parada
